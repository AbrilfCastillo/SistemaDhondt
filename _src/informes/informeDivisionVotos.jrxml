	<queryString>
		<![CDATA[SELECT p.id, p.nombre, p.votos, d.orden, d.votosPorCargo, d.indice, d.entraPorcentaje, d.ocupaCargo,
       (CDBL(p.Votos) / CDBL((SELECT SUM(p2.Votos) FROM Partidos p2)) * 100) AS porcentaje,
       (SELECT SUM(p2.votos) FROM partidos p2) AS totalVotos
FROM partidos p INNER JOIN divisionvotos d ON p.id = d.fk_idPartido
ORDER BY p.id, d.indice]]>
	</queryString>
