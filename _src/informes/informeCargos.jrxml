	<subDataset name="dataset1" uuid="ce173dc5-be33-4186-b2e7-582fef3acf2c"/>
	<queryString>
		<![CDATA[SELECT p.id, p.nombre, p.votos, r.orden, r.cantidadVotos, r.indice, r.porcentaje, r.totalVotos,
       (SELECT COUNT(*) FROM resultadovotos r2 WHERE r2.fk_idPartido = p.id) AS cantidadCargos
FROM partidos p INNER JOIN resultadovotos r ON p.id = r.fk_idPartido
ORDER BY p.id, r.orden]]>
	</queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="votos" class="java.lang.Integer"/>
