	<queryString language="SQL">
		<![CDATA[SELECT p.id, p.nombre, p.votos,
       (CDBL(p.votos) / CDBL((SELECT SUM(p2.votos) FROM partidos p2)) * 100) AS porcentaje,
       (SELECT TOP 1 d.entraPorcentaje FROM divisionvotos d WHERE d.fk_idPartido = p.Id) AS entraPorcentaje
FROM partidos p
ORDER BY p.id]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="votos" class="java.lang.Integer"/>
	<field name="PORCENTAJE" class="java.lang.Double"/>
	<field name="ENTRAPORCENTAJE" class="java.lang.Boolean"/>
